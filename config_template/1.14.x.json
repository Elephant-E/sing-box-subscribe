{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "",
    "timestamp": false
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "address": ["172.18.0.1/30"],
      "auto_route": true,
      "strict_route": true
    }
  ],
  "outbounds": [
    {
      "type": "urltest", 
      "tag": "Auto", 
      "url": "https://www.gstatic.com/generate_204", 
      "interval": "3m", 
      "tolerance": 150, 
      "interrupt_exist_connections": false, 
      "outbounds": [
        "{all}"
      ]
    }, 
    {
      "type": "direct",
      "tag": "Direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic",
          "dns"
        ]
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "protocol": "dns"
          },
          {
            "port": 53
          }
        ],
        "action": "hijack-dns"
      },
      {
        "action": "route",
        "ip_is_private": true,
        "outbound": "Direct"
      },
      {
        "action": "route",
        "clash_mode": "direct",
        "outbound": "Direct"
      },
      {
        "action": "route",
        "clash_mode": "global",
        "outbound": "Auto"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoSite-Github"
        ],
        "outbound": "Auto"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoSite-Private",
          "GeoSite-Direct",
          "GeoSite-Apple",
          "GeoSite-Microsoft"
        ],
        "outbound": "Direct"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoSite-!CN"
        ],
        "outbound": "Auto"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoSite-CN"
        ],
        "outbound": "Direct"
      },
      {
        "action": "resolve"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoIP-CN"
        ],
        "outbound": "Direct"
      }
    ],
    "rule_set": [
      {
        "tag": "GeoSite-Direct",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/Elephant-E/Rules/refs/heads/main/Sing-Box/direct.json",
        "format": "source"
      },
      {
        "tag": "GeoSite-Github",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/github.srs",
        "format": "binary"
      },
      {
        "tag": "GeoSite-Apple",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/apple.srs",
        "format": "binary"
      },
      {
        "tag": "GeoSite-Microsoft",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/microsoft.srs",
        "format": "binary"
      },
      {
        "tag": "GeoSite-Private",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/private.srs",
        "format": "binary"
      },
      {
        "tag": "GeoSite-!CN", 
        "type": "remote", 
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/geolocation-!cn.srs",
        "format": "binary"
      },
      {
        "tag": "GeoSite-CN",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/cn.srs",
        "format": "binary"
      },
      {
        "tag": "GeoIP-CN",
        "type": "remote",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/cn.srs",
        "format": "binary"
      }
    ],
    "auto_detect_interface": true,
    "final": "Auto",
    "default_domain_resolver": {
      "server": "Local-DNS"
    }
  },
  "dns": {
    "servers": [
      {
        "tag": "Local-DNS",
        "type": "local",
        "prefer_go": true
      },
      {
        "tag": "Remote-DNS",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "action": "reject",
        "query_type": [
          "HTTPS"
        ]
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": [
              "GeoSite-Private"
            ],
            "invert": true
          },
          {
            "query_type": [
              "A",
              "AAAA"
            ]
          }
        ],
        "action": "route",
        "server": "Remote-DNS",
        "rewrite_ttl": 1
      }
    ],
    "final": "Local-DNS"
  }
}
