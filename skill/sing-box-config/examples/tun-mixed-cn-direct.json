{
  "log": {
    "level": "info"
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.18.0.1/30"
      ],
      "auto_route": true,
      "strict_route": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],
  "outbounds": [
    {
      "type": "urltest",
      "tag": "Auto",
      "url": "http://cp.cloudflare.com/generate_204",
      "interval": "30m",
      "tolerance": 100,
      "interrupt_exist_connections": true,
      "outbounds": [
        "{all}"
      ]
    },
    {
      "type": "direct",
      "tag": "Direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic",
          "dns"
        ]
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "protocol": "dns"
          },
          {
            "port": 53
          }
        ],
        "action": "hijack-dns"
      },
      {
        "action": "route",
        "ip_is_private": true,
        "outbound": "Direct"
      },
      {
        "action": "route",
        "clash_mode": "direct",
        "outbound": "Direct"
      },
      {
        "action": "route",
        "clash_mode": "global",
        "outbound": "Auto"
      },
      {
        "action": "route",
        "rule_set": [
          "GeoSite-Private",
          "GeoSite-Direct",
          "GeoSite-Apple",
          "GeoSite-Microsoft",
          "GeoSite-CN"
        ],
        "outbound": "Direct"
      },
      {
        "action": "route",
        "rule_set": ["GeoSite-!CN"],
        "outbound": "Auto"
      },
      {
        "action": "resolve"
      },
      {
        "action": "route",
        "rule_set": ["GeoIP-CN"],
        "outbound": "Direct"
      }
    ],
    "rule_set": [
      {
        "type": "remote",
        "tag": "GeoSite-Direct",
        "format": "source",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/Elephant-E/Rules/refs/heads/main/Sing-Box/direct.json"
      },
      {
        "type": "remote",
        "tag": "GeoSite-!CN",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/geolocation-!cn.srs"
      },
      {
        "type": "remote",
        "tag": "GeoSite-Apple",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/apple.srs"
      },
      {
        "type": "remote",
        "tag": "GeoSite-Microsoft",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/microsoft.srs"
      },
      {
        "type": "remote",
        "tag": "GeoSite-Private",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/private.srs"
      },
      {
        "type": "remote",
        "tag": "GeoSite-CN",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geosite/cn.srs"
      },
      {
        "type": "remote",
        "tag": "GeoIP-CN",
        "format": "binary",
        "http_client": "rule-downloader",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/refs/heads/sing/geo/geoip/cn.srs"
      }
    ],
    "final": "Auto",
    "auto_detect_interface": true,
    "default_domain_resolver": {
      "server": "Local-DNS"
    },
    "default_http_client": "rule-downloader"
  },
  "dns": {
    "servers": [
      {
        "tag": "Local-DNS",
        "type": "local"
      },
      {
        "tag": "Remote-DNS",
        "type": "https",
        "server": "1.1.1.1",
        "server_port": 443
      }
    ],
    "rules": [
      {
        "action": "reject",
        "query_type": [
          "HTTPS"
        ]
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "rule_set": [
              "GeoSite-Private"
            ],
            "invert": true
          },
          {
            "query_type": [
              "A",
              "AAAA"
            ]
          }
        ],
        "action": "route",
        "server": "Remote-DNS"
      }
    ],
    "final": "Local-DNS"
  },
  "http_clients": [
    {
      "tag": "rule-downloader",

      "domain_resolver": {
        "server": "Local-DNS"
      }
    }
  ]
}